{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "outDir": "./out/renderer",
    "rootDir": ".",
    "noEmit": true
  },
  "include": [
    "src/renderer/**/*",
    "src/shared/**/*"
  ]
}
